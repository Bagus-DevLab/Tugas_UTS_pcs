						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"disease_id\": 1,\n    \"type\": \"chemical\",\n    \"description\": \"Aplikasi fungisida test\",\n    \"dosage\": \"2.5\",\n    \"dosage_unit\": \"ml/L\",\n    \"priority\": 1\n}"

						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"code\": \"G99\",\n    \"name\": \"Updated symptom\",\n    \"description\": \"Updated description\"\n}"
						},
						"url": { "raw": "{{base_url}}/admin/symptoms/1", "host": ["{{base_url}}"], "path": ["admin", "symptoms", "1"] }
					}
				},
				{
					"name": "Delete Symptom",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/admin/symptoms/1", "host": ["{{base_url}}"], "path": ["admin", "symptoms", "1"] }
					}
				}
			]
		},
		{
			"name": "Admin - Treatments (admin+)",
			"item": [
				{
					"name": "List Treatments (Admin)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/admin/treatments", "host": ["{{base_url}}"], "path": ["admin", "treatments"] }
					}
				},
				{
					"name": "Create Treatment",
					"request": {

						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Disease\",\n    \"description\": \"Updated description\",\n    \"cause\": \"Updated cause\"\n}"
						},
						"url": { "raw": "{{base_url}}/admin/diseases/1", "host": ["{{base_url}}"], "path": ["admin", "diseases", "1"] }
					}
				},
				{
					"name": "Delete Disease",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/admin/diseases/1", "host": ["{{base_url}}"], "path": ["admin", "diseases", "1"] }
					}
				}
			]
		},
		{
			"name": "Admin - Symptoms (admin+)",
			"item": [
				{
					"name": "List Symptoms (Admin)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/admin/symptoms", "host": ["{{base_url}}"], "path": ["admin", "symptoms"] }
					}

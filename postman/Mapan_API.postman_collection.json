		},
		{
			"name": "Admin - Detections (admin+)",
			"item": [
				{
					"name": "List All Detections (Admin)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": {
							"raw": "{{base_url}}/admin/detections",
							"host": ["{{base_url}}"],
							"path": ["admin", "detections"],
							"query": [{ "key": "method", "value": "image", "disabled": true }]
						}
					}
				}
			]
		},
		{
			"name": "Admin - Users (super_admin)",
			"item": [

							"raw": "{\n    \"name\": \"Test Disease\",\n    \"latin_name\": \"Testus diseaseus\",\n    \"description\": \"Deskripsi penyakit test\",\n    \"cause\": \"Penyebab penyakit test\",\n    \"symptoms\": [\n        { \"id\": 1, \"weight\": 0.9 },\n        { \"id\": 2, \"weight\": 0.8 }\n    ]\n}"
						},
						"url": { "raw": "{{base_url}}/admin/diseases", "host": ["{{base_url}}"], "path": ["admin", "diseases"] }
					}
				},
				{

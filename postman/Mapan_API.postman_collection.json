							"raw": "{\n    \"code\": \"G99\",\n    \"name\": \"Gejala test baru\",\n    \"description\": \"Deskripsi gejala test\"\n}"
						},
						"url": { "raw": "{{base_url}}/admin/symptoms", "host": ["{{base_url}}"], "path": ["admin", "symptoms"] }
					}
				},
				{
					"name": "Update Symptom",
					"request": {
